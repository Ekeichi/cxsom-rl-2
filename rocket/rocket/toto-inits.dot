digraph All {

  subgraph cluster_t0 {
    label = <<font point-size="30">timeline <b>rlx</b></font>>
    fillcolor = "#fff0ff"
    style = "filled"
    penwidth = 0

    subgraph cluster_p0 {
      label = "/error"
      fillcolor = "#ffccff"
      style = "filled"
      penwidth = 0
      n1 [label=<<b>Ae-0</b><br/><font point-size="8">Map1D&lt;Scalar&gt;=1500</font>>, shape=box, fillcolor="#ccccff", style="filled"]
      n0 [label=<<b>BMU</b><br/><font point-size="8">Pos1D</font>>, shape=box, fillcolor="#ccccff", style="filled"]
      u0 [label=<<b>conv-argmax</b><br/><font point-size="10">beta = 0.5</font><br/><font point-size="10">deadline = 100</font><br/><font point-size="10">delta = 0.01</font><br/><font point-size="10">epsilon = 0</font><br/><font point-size="10">random-bmu = 1</font><br/><font point-size="10">sigma = 0.01</font><br/><font point-size="10">walltime = -1</font>>, shape=ellipse, fillcolor="#ffffaa", style="filled"]
    }

    subgraph cluster_p1 {
      label = "/speed"
      fillcolor = "#ffccff"
      style = "filled"
      penwidth = 0
      n3 [label=<<b>Ae-0</b><br/><font point-size="8">Map1D&lt;Scalar&gt;=1500</font>>, shape=box, fillcolor="#ccccff", style="filled"]
      n2 [label=<<b>BMU</b><br/><font point-size="8">Pos1D</font>>, shape=box, fillcolor="#ccccff", style="filled"]
      u1 [label=<<b>conv-argmax</b><br/><font point-size="10">beta = 0.5</font><br/><font point-size="10">deadline = 100</font><br/><font point-size="10">delta = 0.01</font><br/><font point-size="10">epsilon = 0</font><br/><font point-size="10">random-bmu = 1</font><br/><font point-size="10">sigma = 0.01</font><br/><font point-size="10">walltime = -1</font>>, shape=ellipse, fillcolor="#ffffaa", style="filled"]
    }
  }
  u0 -> n0
  n1 -> u0
  u1 -> n2
  n3 -> u1
}
